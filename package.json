{
  "name": "paax-ai",
  "private": true,
  "version": "0.2.0-demo",
  "type": "module",
  "description": "PAAX AI v0.2-demo browser app for demo AHSP/RAB workflows.",
  "scripts": {
    "dev": "tsx server.ts",
    "lint": "tsc --noEmit",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "check": "npm run lint && npm run build",
    "start": "node dist/server.cjs"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^8.0.16"
  }
}
