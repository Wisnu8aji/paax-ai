{
  "name": "paax-ai",
  "private": true,
  "version": "0.3.0",
  "description": "PAAX AI - Civil Engineering AI Workspace. Professional monorepo.",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean",
    "dev:web": "turbo dev --filter=@paax/web",
    "dev:core": "cd services/core-engine && python -m uvicorn app.main:app --reload --port 8081",
    "dev:ai": "turbo dev --filter=@paax/ai-orchestrator"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.6",
    "@types/http-errors": "^2.0.5",
    "@types/node": "22.0.0",
    "@types/qs": "^6.15.1",
    "@types/range-parser": "^1.2.7",
    "@types/send": "^1.2.1",
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@9.15.0"
}
