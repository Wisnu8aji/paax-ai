# PAAX Web App — Environment Variables
# Copy ke .env.local dan sesuaikan bila perlu.

# URL Core Engine (FastAPI). Halaman /rab-tester memanggil engine ini.
NEXT_PUBLIC_CORE_ENGINE_URL=http://localhost:8081

# Firebase/Firestore (opsional untuk dev lokal).
# Jika salah satu nilai kosong, workspace proyek otomatis memakai localStorage fallback.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_APP_ID=

# AI ekstraksi (opsional). TANPA ini, "Susun dengan AI" pakai otak rule-based (gratis).
# Gemini punya free tier di Google AI Studio (https://aistudio.google.com/apikey).
# Server-side saja — JANGAN pakai prefix NEXT_PUBLIC (agar key tak terekspos ke browser).
GEMINI_API_KEY=
